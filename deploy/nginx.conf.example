# career-nav Nginx 配置 — 子路径部署 https://h100.jsai100.com/a300
# 将以下两个 location 块追加到已有 h100.jsai100.com HTTPS server block 中
# 部署后：sudo nginx -t && sudo systemctl reload nginx

# ===== 以下内容追加到 h100.jsai100.com 的 443 server block 内 =====

    # career-nav 静态资源（/_next/static）
    # assetPrefix="/a300" 让浏览器请求 /a300/_next/...，这里负责剥去前缀再转给 Next.js
    location ^~ /a300/_next/ {
        rewrite ^/a300(/_next/.+)$ $1 break;
        proxy_pass http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
        # 带 hash 的静态文件可以长缓存
        proxy_cache_valid 200 30d;
        add_header Cache-Control "public, max-age=31536000, immutable";
    }

    # career-nav 全部页面 + API（含简历上传、报告生成）
    # basePath="/a300"：Next.js 识别路径前缀，无需在 nginx 层剥除
    location /a300 {
        proxy_pass http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        # AI 接口响应慢，给足时间
        proxy_read_timeout 180s;
        proxy_send_timeout 180s;
        proxy_connect_timeout 10s;
        proxy_buffering off;
        # 简历上传最大 15MB
        client_max_body_size 15m;
    }

# ===== 完整 server block 示例（新机器参考）=====
