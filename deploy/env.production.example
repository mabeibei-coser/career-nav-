# career-nav 生产环境变量模板
# 真实值写到 .env.production.local（不进版本库）
# 复制到服务器：cp deploy/env.production.example .env.production.local && vim .env.production.local

# === Next.js 子路径部署（必须与 next.config.ts basePath 一致）===
NEXT_PUBLIC_BASE_PATH=/a300

# === LLM 主链路：DeepSeek ===
# DEEPSEEK_MODEL 在 lib/deepseek.ts 锁死为 "deepseek-v4-flash"，不读 env
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# === LLM 兜底链路：讯飞 iFlytek（留空则双链路失败时直接走 mock）===
IFLYTEK_API_KEY=your_iflytek_api_key_here
IFLYTEK_BASE_URL=https://maas-coding-api.cn-huabei-1.xf-yun.com/v2
IFLYTEK_MODEL=astron-code-latest

# === 火山引擎 TTS + ASR（ASR 复用 TTS 的 key，见 lib/volc-asr-batch.ts）===
VOLC_TTS_APP_KEY=your_volc_tts_app_key
VOLC_TTS_ACCESS_KEY=your_volc_tts_access_key
VOLC_TTS_SPEAKER=zh_female_vv_uranus_bigtts

# === iron-session（必须，至少 32 字节随机）===
# 生成方法：openssl rand -base64 32
SESSION_SECRET=replace_with_at_least_32_random_bytes_base64

# === Node / Next.js 运行端口（career-report 占 3000，career-nav 用 3001）===
PORT=3003
NODE_ENV=production
